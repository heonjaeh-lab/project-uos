# 조심해야댕 — 실데이터 API 키 (이 파일을 복사해 .env 로 저장하고 값 채우기)
# .env 는 .gitignore 로 제외됨 — 절대 커밋되지 않는다.

# ── 공공데이터포털 (https://www.data.go.kr) : 계정 1개 인증키로 여러 API 활용신청 ──
# 단기예보, 생활기상지수(자외선), 에어코리아 대기질(PM), TourAPI 등에 사용.
DATA_GO_KR_KEY=

# ── 기상청 API 허브 (https://apihub.kma.go.kr) : 지상관측(ASOS) 등 ──
KMA_APIHUB_KEY=

# ── 네이버 지도 (NCP) : 지도 표시(디자인 단계). 엔진엔 불필요 ──
NAVER_MAP_KEY=

# ── 서울 열린데이터광장 (https://data.seoul.go.kr) : 인증키 1개 ──
# 가로수, 가로등, 공원, 반려견놀이터, 도로굴착 공사, TOPIS 실시간 교통 등에 사용.
SEOUL_OPEN_DATA_KEY=

# ── V-World (https://www.vworld.kr) : 인증키 (선택) ──
# 건물 높이/3D. OSM height 태그로 대체 가능하므로 없으면 OSM로 폴백.
VWORLD_KEY=
